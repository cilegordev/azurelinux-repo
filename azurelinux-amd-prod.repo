[azurelinux-amd-prod]
name=Azure Linux Official amd prod $releasever $basearch
baseurl=https://packages.microsoft.com/azurelinux/$releasever/prod/amd/$basearch
gpgkey=https://packages.microsoft.com/azurelinux/$releasever/prod/amd/$basearch/repodata/repomd.xml.key
gpgcheck=1
repo_gpgcheck=1
enabled=1
skip_if_unavailable=True
sslverify=1
