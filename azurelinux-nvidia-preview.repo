[azurelinux-NVIDIA-preview]
name=Azure Linux Official NVIDIA Preview $releasever $basearch
baseurl=https://packages.microsoft.com/azurelinux/$releasever/preview/NVIDIA/$basearch
gpgkey=https://packages.microsoft.com/azurelinux/$releasever/preview/NVIDIA/$basearch/repodata/repomd.xml.key
gpgcheck=1
repo_gpgcheck=1
enabled=1
skip_if_unavailable=True
sslverify=1
