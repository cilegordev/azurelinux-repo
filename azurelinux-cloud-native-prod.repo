[azurelinux-cloud-native-prod]
name=Azure Linux Official prod $releasever $basearch
baseurl=https://packages.microsoft.com/azurelinux/$releasever/prod/cloud-native/$basearch
gpgkey=https://packages.microsoft.com/azurelinux/$releasever/prod/cloud-native/$basearch/repodata/repomd.xml.key
gpgcheck=1
repo_gpgcheck=1
enabled=1
skip_if_unavailable=True
sslverify=1
